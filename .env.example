# ──────────────────────────────────────────────────────────────
# isA Docs — Environment Configuration
#
# Copy to `.env.local` and adjust for your environment.
# All NEXT_PUBLIC_ vars are available in both server and client code.
# ──────────────────────────────────────────────────────────────

# ── Platform Surfaces ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.isa.io
NEXT_PUBLIC_STATUS_URL=https://status.isa.io
NEXT_PUBLIC_CONSOLE_URL=https://console.isa.io
NEXT_PUBLIC_APP_URL=https://app.isa.io
NEXT_PUBLIC_DOCS_URL=https://docs.isa.io

# ── Community ─────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_ORG_URL=https://github.com/xenoISA
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/isa
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/isA_platform

# ── Docs Repo (for "Edit this page" links) ───────────────────
NEXT_PUBLIC_DOCS_REPO=https://github.com/xenoISA/isA_Docs

# ── AI Search Backend ─────────────────────────────────────────
QDRANT_URL=http://localhost:6333
MODEL_URL=http://localhost:8082
QDRANT_COLLECTION=isa_docs
